<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:system="clr-namespace:System;assembly=mscorlib">
    
    <!-- Spacing Scale -->
    <system:Double x:Key="SpacingXs">4</system:Double>
    <system:Double x:Key="SpacingSm">8</system:Double>
    <system:Double x:Key="SpacingMd">12</system:Double>
    <system:Double x:Key="SpacingLg">16</system:Double>
    <system:Double x:Key="SpacingXl">24</system:Double>
    <system:Double x:Key="SpacingXxl">32</system:Double>

    <!-- Generic Thickness (Margins/Paddings) -->
    <Thickness x:Key="ThicknessNone">0</Thickness>
    <Thickness x:Key="ThicknessXs">4</Thickness>
    <Thickness x:Key="ThicknessSm">8</Thickness>
    <Thickness x:Key="ThicknessMd">12</Thickness>
    <Thickness x:Key="ThicknessLg">16</Thickness>
    <Thickness x:Key="ThicknessXl">24</Thickness>
    
    <!-- Component Paddings -->
    <Thickness x:Key="PaddingButton">12,8</Thickness>
    <Thickness x:Key="PaddingButtonSmall">8,4</Thickness>
    <Thickness x:Key="PaddingInput">12,8</Thickness>
    <Thickness x:Key="PaddingContainer">16</Thickness>
    <Thickness x:Key="PaddingComboBoxItem">8,6</Thickness>
    <Thickness x:Key="PaddingComboBox">12,6</Thickness>
    
    <!-- Radii -->
    <CornerRadius x:Key="RadiusSm">4</CornerRadius>
    <CornerRadius x:Key="RadiusMd">6</CornerRadius>
    <CornerRadius x:Key="RadiusLg">8</CornerRadius>

    <!-- Component Sizes -->
    <system:Double x:Key="IconSizeSm">12</system:Double>
    <system:Double x:Key="IconSizeMd">16</system:Double>
    <system:Double x:Key="IconSizeLg">20</system:Double>
    
    <!-- Checkbox / Radio Sizes -->
    <system:Double x:Key="ControlBoxSize">16</system:Double>
    <system:Double x:Key="RadioCheckSize">6</system:Double>

    <!-- Control Heights -->
    <system:Double x:Key="TitleBarHeight">48</system:Double>
</ResourceDictionary>
