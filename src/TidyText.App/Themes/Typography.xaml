<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:system="clr-namespace:System;assembly=mscorlib">
    
    <!-- Font Families -->
    <FontFamily x:Key="BrandFontFamily">Segoe UI, -apple-system, BlinkMacSystemFont, Roboto, sans-serif</FontFamily>
    <FontFamily x:Key="CodeFontFamily">Consolas, Courier New, monospace</FontFamily>
    <FontFamily x:Key="IconFontFamily">Segoe UI Symbol, Segoe MDL2 Assets, sans-serif</FontFamily>
    
    <!-- Font Sizes -->
    <system:Double x:Key="FontSizeXs">10</system:Double>
    <system:Double x:Key="FontSizeSm">11</system:Double>
    <system:Double x:Key="FontSizeMd">12</system:Double>
    <system:Double x:Key="FontSizeBase">13</system:Double>
    <system:Double x:Key="FontSizeNormal">14</system:Double>
    <system:Double x:Key="FontSizeLg">16</system:Double>
    <system:Double x:Key="FontSizeXl">18</system:Double>

    <!-- Font Weights -->
    <FontWeight x:Key="FontWeightNormal">Normal</FontWeight>
    <FontWeight x:Key="FontWeightSemiBold">SemiBold</FontWeight>
    <FontWeight x:Key="FontWeightBold">Bold</FontWeight>

</ResourceDictionary>
