<UserControl x:Class="TidyText.App.Views.AIAssistantPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:vm="clr-namespace:TidyText.App.ViewModels"
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="380">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 1. Header (Pinned Top) -->
        <Border Grid.Row="0" Margin="0,0,0,16" Background="{DynamicResource PanelBgBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="6" Padding="2">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="90"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <ComboBox Grid.Column="0" ItemsSource="{Binding AvailableProviders}" SelectedItem="{Binding ActiveProviderName}" 
                          BorderThickness="0" Background="Transparent" Foreground="{DynamicResource TextMutedBrush}" Padding="4,2"/>
                <Rectangle Grid.Column="1" Width="1" Fill="{DynamicResource BorderBrush}" Margin="2,4"/>
                <ComboBox Grid.Column="2" ItemsSource="{Binding AvailableModels}" SelectedItem="{Binding ActiveModel}" 
                          BorderThickness="0" Background="Transparent" Foreground="{DynamicResource TextBrush}" FontWeight="SemiBold" Padding="4,2"/>
            </Grid>
        </Border>
        
        <!-- 2. Main Scrollable Area (Middle) -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,0,0,16">
            <StackPanel>
                
                <TextBlock Text="Quick Actions" FontSize="{DynamicResource FontSizeNormal}" FontWeight="SemiBold" Margin="0,0,0,12" Foreground="{DynamicResource TextBrush}"/>
                
                <ItemsControl ItemsSource="{Binding Templates}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Command="{Binding DataContext.ExecuteTemplateCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}" 
                                    CommandParameter="{Binding}"
                                    Style="{StaticResource AIActionButtonStyle}"
                                    Effect="{DynamicResource SoftGlow}">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Icon}" Margin="0,0,12,0" VerticalAlignment="Center" FontSize="{DynamicResource FontSizeMd}"/>
                                    <TextBlock Text="{Binding Name}" VerticalAlignment="Center" FontWeight="SemiBold" FontSize="{DynamicResource FontSizeNormal}" Foreground="{DynamicResource TextBrush}"/>
                                </StackPanel>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

            </StackPanel>
        </ScrollViewer>

        <!-- 3. Custom Prompt (Pinned Bottom) -->
        <Border Grid.Row="2" Background="{DynamicResource PanelBgBrush}" Margin="-8,0,-8,-8" Padding="8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="100"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
            
            <TextBlock Grid.Row="0" Text="Custom Prompt" FontSize="{DynamicResource FontSizeNormal}" FontWeight="SemiBold" Margin="0,0,0,8" Foreground="{DynamicResource TextBrush}"/>
            
            <Grid Grid.Row="1">
                <TextBox Text="{Binding CustomPrompt, UpdateSourceTrigger=PropertyChanged}" 
                         TextWrapping="Wrap" AcceptsReturn="True" 
                         VerticalScrollBarVisibility="Auto"
                         Background="{DynamicResource BgBrush}" BorderThickness="1" BorderBrush="{DynamicResource BorderBrush}" Padding="12"
                         Foreground="{DynamicResource TextBrush}" CaretBrush="{DynamicResource TextBrush}"
                         FontFamily="{DynamicResource BrandFontFamily}" FontSize="{DynamicResource FontSizeNormal}" />
                <TextBlock IsHitTestVisible="False" Text="Ask AI to modify text or write something..." TextWrapping="Wrap" VerticalAlignment="Top" HorizontalAlignment="Stretch" Margin="14,14,14,0" Foreground="{DynamicResource TextMutedBrush}" FontSize="{DynamicResource FontSizeNormal}">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding CustomPrompt}" Value="">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Grid>
                     
            <Grid Grid.Row="2" Margin="0,8,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <ProgressBar IsIndeterminate="True" Height="4" Margin="0,0,8,4" Background="{DynamicResource BorderBrush}" Foreground="{DynamicResource AccentBrush}" Visibility="{Binding IsProcessing, Converter={StaticResource BoolToVis}}" />
                    <TextBlock Text="{Binding StatusMessage}" Foreground="{DynamicResource TextMutedBrush}" TextWrapping="Wrap" FontSize="{DynamicResource FontSizeNormal}">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsProcessing}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>
                
                <Button Grid.Column="1" Padding="16,6" MinWidth="80">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
                            <Setter Property="Content" Value="Submit"/>
                            <Setter Property="Command" Value="{Binding ExecuteCustomPromptCommand}"/>
                            <Setter Property="Effect" Value="{DynamicResource AccentGlow}"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsProcessing}" Value="True">
                                    <Setter Property="Content" Value="Stop"/>
                                    <Setter Property="Command" Value="{Binding CancelProcessingCommand}"/>
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="Foreground" Value="{DynamicResource DangerTextBrush}"/>
                                    <Setter Property="BorderBrush" Value="{DynamicResource DangerBrush}"/>
                                    <Setter Property="BorderThickness" Value="1"/>
                                    <Setter Property="Effect" Value="{x:Null}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>
            </Grid>
        </Border>

        <!-- Review Mode Overlay -->
        <Border Grid.Row="0" Grid.RowSpan="3" Background="{DynamicResource BgBrush}" 
                Visibility="{Binding IsReviewing, Converter={StaticResource BoolToVis}}" Margin="-8,-8,-8,-8" Padding="12,12,12,12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                
                <TextBlock Grid.Row="0" Text="Review Proposed Changes" FontSize="{DynamicResource FontSizeLarge}" FontWeight="Bold" Margin="0,0,0,12" Foreground="{DynamicResource TextBrush}"/>
                
                <Border Grid.Row="1" Background="{DynamicResource PanelBgBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="4" Padding="8">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding DiffChunks}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border x:Name="chunkBorder" CornerRadius="2" Margin="0,0,0,2">
                                        <TextBlock x:Name="chunkText" Text="{Binding Text}" FontFamily="{DynamicResource CodeFontFamily}" FontSize="{DynamicResource FontSizeNormal}" TextWrapping="Wrap" Foreground="{DynamicResource TextBrush}"/>
                                    </Border>
                                    <DataTemplate.Triggers>
                                        <DataTrigger Binding="{Binding Type}" Value="{x:Static vm:DiffChunkType.Inserted}">
                                            <Setter TargetName="chunkBorder" Property="Background" Value="{DynamicResource SuccessBgBrush}"/>
                                            <Setter TargetName="chunkText" Property="Foreground" Value="{DynamicResource SuccessTextBrush}"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Type}" Value="{x:Static vm:DiffChunkType.Deleted}">
                                            <Setter TargetName="chunkBorder" Property="Background" Value="{DynamicResource DiffDeletedBgBrush}"/>
                                            <Setter TargetName="chunkText" Property="Foreground" Value="{DynamicResource DiffDeletedTextBrush}"/>
                                            <Setter TargetName="chunkText" Property="TextDecorations" Value="Strikethrough"/>
                                        </DataTrigger>
                                    </DataTemplate.Triggers>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Border>
                
                <Grid Grid.Row="2" Margin="0,16,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Content="❌ Reject" Command="{Binding RejectChangesCommand}" Padding="8,10" FontWeight="SemiBold"
                            Background="Transparent" BorderThickness="1" BorderBrush="{DynamicResource BorderBrush}" Foreground="{DynamicResource TextBrush}"/>
                    <Button Grid.Column="2" Content="✅ Accept" Command="{Binding AcceptChangesCommand}" Padding="8,10" FontWeight="SemiBold"
                            Style="{StaticResource PrimaryButtonStyle}" Effect="{DynamicResource AccentGlow}"/>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
