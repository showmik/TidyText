<UserControl x:Class="TidyText.App.Views.AIAssistantPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="380">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="✨ AI Assistant" FontSize="20" FontWeight="Bold" Margin="0,0,0,16" Foreground="{StaticResource TextBrush}"/>
        
        <TextBlock Grid.Row="1" Text="Actions" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,12" Foreground="{StaticResource TextBrush}"/>
        
        <ItemsControl Grid.Row="2" ItemsSource="{Binding Templates}" ScrollViewer.VerticalScrollBarVisibility="Auto">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Button Command="{Binding DataContext.ExecuteTemplateCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}" 
                            CommandParameter="{Binding}"
                            Background="{StaticResource PanelBgBrush}" BorderThickness="1" BorderBrush="{StaticResource BorderBrush}" Margin="0,0,0,8" Padding="12"
                            HorizontalContentAlignment="Left" Cursor="Hand" Effect="{StaticResource SoftGlow}">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="{Binding Icon}" Margin="0,0,12,0" VerticalAlignment="Center" FontSize="16"/>
                            <TextBlock Text="{Binding Name}" VerticalAlignment="Center" FontWeight="SemiBold" FontSize="14" Foreground="{StaticResource TextBrush}"/>
                        </StackPanel>
                    </Button>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <Grid Grid.Row="3" Margin="0,16,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="200"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            
            <TextBlock Grid.Row="0" Text="{Binding StatusMessage}" Margin="0,0,0,8" Foreground="{StaticResource TextMutedBrush}" TextWrapping="Wrap" />
            
            <TextBox Grid.Row="1" Text="{Binding ResponseContent}" 
                     TextWrapping="Wrap" AcceptsReturn="True" 
                     VerticalScrollBarVisibility="Auto"
                     Background="{StaticResource PanelBgBrush}" BorderThickness="1" BorderBrush="{StaticResource BorderBrush}" Padding="12" IsReadOnly="True"
                     Foreground="{StaticResource TextBrush}" CaretBrush="{StaticResource TextBrush}"
                     FontFamily="Consolas" FontSize="14" />
                     
            <Button Grid.Row="2" Content="Apply to Editor" Command="{Binding ApplyResponseToEditorCommand}" 
                    Style="{StaticResource PrimaryButtonStyle}" Margin="0,12,0,0" Effect="{StaticResource AccentGlow}"/>
        </Grid>
    </Grid>
</UserControl>
