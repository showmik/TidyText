<Window x:Class="TidyText.App.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings" Height="420" Width="480"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="{StaticResource BgBrush}"
        FontFamily="Segoe UI, -apple-system, BlinkMacSystemFont, Roboto, sans-serif">
    
    <Grid Margin="32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <TextBlock Text="AI Provider API Keys" FontSize="24" FontWeight="Bold" Margin="0,0,0,24" Foreground="{StaticResource TextBrush}"/>
        
        <StackPanel Grid.Row="1" Margin="0,0,0,20">
            <TextBlock Text="Gemini API Key:" Margin="0,0,0,8" FontWeight="SemiBold" Foreground="{StaticResource TextMutedBrush}"/>
            <TextBox Text="{Binding GeminiApiKey, UpdateSourceTrigger=PropertyChanged}"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Margin="0,0,0,20">
            <TextBlock Text="DeepSeek API Key:" Margin="0,0,0,8" FontWeight="SemiBold" Foreground="{StaticResource TextMutedBrush}"/>
            <TextBox Text="{Binding DeepSeekApiKey, UpdateSourceTrigger=PropertyChanged}"/>
        </StackPanel>

        <StackPanel Grid.Row="3" Margin="0,0,0,20">
            <TextBlock Text="OpenAI API Key:" Margin="0,0,0,8" FontWeight="SemiBold" Foreground="{StaticResource TextMutedBrush}"/>
            <TextBox Text="{Binding OpenAIApiKey, UpdateSourceTrigger=PropertyChanged}"/>
        </StackPanel>
        
        <TextBlock Grid.Row="4" Text="{Binding StatusMessage}" Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center" TextWrapping="Wrap"/>

        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="Save Keys" Command="{Binding SaveKeysCommand}" Style="{StaticResource PrimaryButtonStyle}" MinWidth="120" Effect="{StaticResource AccentGlow}"/>
        </StackPanel>
    </Grid>
</Window>
