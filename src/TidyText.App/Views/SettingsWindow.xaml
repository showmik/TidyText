<Window x:Class="TidyText.App.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings" Height="350" Width="400"
        Background="#1E1E1E" Foreground="#E0E0E0"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <TextBlock Text="AI Provider API Keys" FontSize="18" FontWeight="Bold" Foreground="#00B4D8" Margin="0,0,0,15"/>
        
        <StackPanel Grid.Row="1" Margin="0,0,0,15">
            <TextBlock Text="Gemini API Key:" Margin="0,0,0,5" FontWeight="SemiBold"/>
            <TextBox Text="{Binding GeminiApiKey, UpdateSourceTrigger=PropertyChanged}" Background="#2D2D30" Foreground="White" BorderBrush="#555555" Padding="5"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Margin="0,0,0,15">
            <TextBlock Text="DeepSeek API Key:" Margin="0,0,0,5" FontWeight="SemiBold"/>
            <TextBox Text="{Binding DeepSeekApiKey, UpdateSourceTrigger=PropertyChanged}" Background="#2D2D30" Foreground="White" BorderBrush="#555555" Padding="5"/>
        </StackPanel>

        <StackPanel Grid.Row="3" Margin="0,0,0,15">
            <TextBlock Text="OpenAI API Key:" Margin="0,0,0,5" FontWeight="SemiBold"/>
            <TextBox Text="{Binding OpenAIApiKey, UpdateSourceTrigger=PropertyChanged}" Background="#2D2D30" Foreground="White" BorderBrush="#555555" Padding="5"/>
        </StackPanel>
        
        <TextBlock Grid.Row="4" Text="{Binding StatusMessage}" Foreground="#00B4D8" VerticalAlignment="Center"/>

        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Save Keys" Command="{Binding SaveKeysCommand}" Padding="15,5" Background="#0077B6" Foreground="White" BorderThickness="0" Cursor="Hand"/>
        </StackPanel>
    </Grid>
</Window>
