<Window x:Class="TidyText.App.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TidyText.App"
        xmlns:viewmodels="clr-namespace:TidyText.App.ViewModels"
        xmlns:views="clr-namespace:TidyText.App.Views"
        mc:Ignorable="d"
        Title="TidyText" Height="800" Width="1200"
        WindowStartupLocation="CenterScreen"
        FontFamily="{DynamicResource BrandFontFamily}"
        Background="{DynamicResource BgBrush}"
        WindowStyle="SingleBorderWindow"
        ResizeMode="CanResize">
        
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="48" CornerRadius="0" GlassFrameThickness="1" UseAeroCaptionButtons="False" />
    </WindowChrome.WindowChrome>
    <Window.InputBindings>
        <KeyBinding Key="Z" Modifiers="Ctrl" Command="{Binding UndoCommand}" />
        <KeyBinding Key="Y" Modifiers="Ctrl" Command="{Binding RedoCommand}" />
        <KeyBinding Key="Z" Modifiers="Ctrl+Shift" Command="{Binding RedoCommand}" />
    </Window.InputBindings>
    
    <!-- Outer Grid to hold Custom Title Bar + Rest of Window -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="48" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Custom Title Bar -->
        <Grid Grid.Row="0" Background="Transparent">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" /> <!-- Branding -->
                <ColumnDefinition Width="*" />    <!-- Drag Area -->
                <ColumnDefinition Width="Auto" /> <!-- Actions -->
                <ColumnDefinition Width="Auto" /> <!-- Window Controls -->
            </Grid.ColumnDefinitions>
            
            <!-- Branding (Left) -->
            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0,0,0">
                <Button Content="≡" Command="{Binding ToggleHistoryPanelCommand}" Style="{StaticResource IconButtonStyle}" FontSize="{DynamicResource FontSizeXl}" Padding="{DynamicResource PaddingButtonSmall}" Margin="0,0,12,0" WindowChrome.IsHitTestVisibleInChrome="True" ToolTip="Toggle History Sidebar"/>
                <TextBlock Text="✨ TidyText"
                           FontSize="{DynamicResource FontSizeLg}"
                           FontWeight="{DynamicResource FontWeightBold}"
                           Foreground="{DynamicResource AccentBrush}"
                           VerticalAlignment="Center"
                           IsHitTestVisible="False" />
            </StackPanel>
            
            <!-- Window Drag Area (Middle) handled natively by WindowChrome -->
            
            <!-- Toolbar Actions (Right, separate from controls) -->
            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,12,0" WindowChrome.IsHitTestVisibleInChrome="True">
                <Button Content="🌗 Theme" Click="ThemeToggle_Click" Style="{StaticResource IconButtonStyle}" Margin="0,0,4,0" ToolTip="Toggle Light/Dark Mode"/>
                <Button Content="⚙️ Settings" Click="SettingsButton_Click" Style="{StaticResource IconButtonStyle}" Margin="0,0,4,0" ToolTip="API Keys &amp; Settings"/>
                <Button Content="↩️ Undo" Command="{Binding UndoCommand}" Style="{StaticResource IconButtonStyle}" Margin="0,0,4,0" ToolTip="Undo Last Clean (Ctrl+Z)"/>
                <Button Content="↪️ Redo" Command="{Binding RedoCommand}" Style="{StaticResource IconButtonStyle}" Margin="0,0,4,0" ToolTip="Redo Last Clean (Ctrl+Y)"/>
                <Button Content="📋 Copy" Command="{Binding CopyCommand}" Style="{StaticResource IconButtonStyle}" Margin="0,0,12,0" ToolTip="Copy Text"/>
                <ToggleButton Content="🤖 AI Assistant" IsChecked="{Binding IsAIPanelOpen}" Padding="12,4" Cursor="Hand" ToolTip="Toggle AI Assistant">
                    <ToggleButton.Style>
                        <Style TargetType="ToggleButton">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="Border" Background="{TemplateBinding Background}" CornerRadius="8">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Border" Property="Background" Value="{DynamicResource HoverBrush}"/>
                                                <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
                                            </Trigger>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter TargetName="Border" Property="Background" Value="{DynamicResource AccentBrush}"/>
                                                <Setter Property="Foreground" Value="{DynamicResource AccentForegroundBrush}"/>
                                            </Trigger>
                                            <MultiTrigger>
                                                <MultiTrigger.Conditions>
                                                    <Condition Property="IsChecked" Value="True"/>
                                                    <Condition Property="IsMouseOver" Value="True"/>
                                                </MultiTrigger.Conditions>
                                                <Setter TargetName="Border" Property="Background" Value="{DynamicResource AccentHoverBrush}"/>
                                                <Setter Property="Foreground" Value="{DynamicResource AccentHoverForegroundBrush}"/>
                                            </MultiTrigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ToggleButton.Style>
                </ToggleButton>
            </StackPanel>
            
            <!-- Window Controls (Far Right) -->
            <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Stretch" WindowChrome.IsHitTestVisibleInChrome="True">
                <Button Content="" Width="46" Click="Minimize_Click" Style="{StaticResource WindowControlButtonStyle}" ToolTip="Minimize"/>
                <Button Content="" Width="46" Click="Maximize_Click" Style="{StaticResource WindowControlButtonStyle}" ToolTip="Maximize"/>
                <Button Content="" Width="46" Click="Close_Click" Style="{StaticResource WindowCloseButtonStyle}" ToolTip="Close"/>
            </StackPanel>
        </Grid>

        <!-- Inner Content Grid -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <!-- Left Sidebar (History) Area -->
                <ColumnDefinition Width="Auto" x:Name="HistoryPanelColumn" />
                <!-- Main Editor Area -->
                <ColumnDefinition Width="*" />
                <!-- AI Panel Area -->
                <ColumnDefinition Width="Auto" x:Name="AIPanelColumn" />
            </Grid.ColumnDefinitions>

            <!-- History Side Panel (Left) -->
            <Border Grid.Column="0" Width="220" Margin="12,12,0,12" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="8" Background="{DynamicResource PanelBgBrush}"
                    Visibility="{Binding IsHistoryPanelOpen, Converter={StaticResource BooleanToVisibilityConverter}}"
                    Effect="{DynamicResource SoftGlow}">
                <Grid Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <Grid Grid.Row="0" Margin="0,0,0,12">
                        <TextBlock Text="🕒 History" FontSize="{DynamicResource FontSizeNormal}" FontWeight="{DynamicResource FontWeightBold}" Foreground="{DynamicResource TextBrush}" VerticalAlignment="Center"/>
                        <Button Command="{Binding AIAssistantVM.ClearHistoryCommand}" HorizontalAlignment="Right" VerticalAlignment="Center" Cursor="Hand" ToolTip="Clear All History">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="Border" Background="Transparent" BorderThickness="1" BorderBrush="{DynamicResource BorderBrush}" CornerRadius="{DynamicResource RadiusSm}" Padding="{DynamicResource PaddingButtonSmall}">
                                        <TextBlock x:Name="BtnText" Text="Clear All" FontSize="{DynamicResource FontSizeSm}" FontWeight="{DynamicResource FontWeightSemiBold}" Foreground="{DynamicResource TextMutedBrush}" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="BtnText" Property="Foreground" Value="{DynamicResource DangerTextBrush}"/>
                                            <Setter TargetName="Border" Property="BorderBrush" Value="{DynamicResource DangerBrush}"/>
                                            <Setter TargetName="Border" Property="Background" Value="{DynamicResource DangerBgBrush}"/>
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter TargetName="Border" Property="Background" Value="{DynamicResource DangerPressedBgBrush}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Grid>
                    
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding AIAssistantVM.History}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{DynamicResource BgBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="4" Margin="0,0,0,4" Padding="8,6" Cursor="Hand">
                                        <Border.InputBindings>
                                            <MouseBinding MouseAction="LeftClick" Command="{Binding ToggleExpandCommand}"/>
                                        </Border.InputBindings>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            
                                            <TextBlock Grid.Row="0" Grid.Column="0" Text="{Binding Prompt}" FontWeight="{DynamicResource FontWeightSemiBold}" FontSize="{DynamicResource FontSizeMd}" Foreground="{DynamicResource TextBrush}" TextTrimming="CharacterEllipsis" Margin="0,0,4,2"/>
                                            <TextBlock Grid.Row="1" Grid.Column="0" Text="{Binding Timestamp, StringFormat='MMM dd, HH:mm'}" FontSize="{DynamicResource FontSizeXs}" Foreground="{DynamicResource TextMutedBrush}"/>
                                            
                                            <StackPanel Grid.Row="0" Grid.RowSpan="2" Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                                <Button Command="{Binding DeleteCommand}" ToolTip="Delete" Margin="0,0,4,0">
                                                    <Button.Template>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border Background="Transparent" Cursor="Hand" Padding="4">
                                                                <TextBlock x:Name="IconText" Text="✕" FontSize="{DynamicResource FontSizeMd}" Foreground="{DynamicResource TextMutedBrush}" Opacity="0.5" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="IconText" Property="Foreground" Value="{DynamicResource DangerTextBrush}"/>
                                                                    <Setter TargetName="IconText" Property="Opacity" Value="1.0"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Button.Template>
                                                </Button>
                                                <Button Content="↩️" Command="{Binding RestoreCommand}" ToolTip="Restore"
                                                        Background="Transparent" BorderThickness="0" Foreground="{DynamicResource AccentBrush}"
                                                        Padding="4" Cursor="Hand" FontSize="{DynamicResource FontSizeNormal}"/>
                                            </StackPanel>
                                                    
                                            <!-- Expanded Content -->
                                            <StackPanel Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,8,0,0"
                                                        Visibility="{Binding IsExpanded, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                <TextBlock Text="Prompt:" FontSize="{DynamicResource FontSizeXs}" FontWeight="{DynamicResource FontWeightSemiBold}" Foreground="{DynamicResource TextMutedBrush}"/>
                                                <TextBlock Text="{Binding Prompt}" FontSize="{DynamicResource FontSizeSm}" Foreground="{DynamicResource TextBrush}" TextWrapping="Wrap" Margin="0,2,0,8"/>
                                                
                                                <TextBlock Text="Result:" FontSize="{DynamicResource FontSizeXs}" FontWeight="{DynamicResource FontWeightSemiBold}" Foreground="{DynamicResource TextMutedBrush}"/>
                                                <TextBlock Text="{Binding GeneratedText}" FontSize="{DynamicResource FontSizeSm}" Foreground="{DynamicResource TextBrush}" TextWrapping="Wrap" Margin="0,2,0,4"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                            <ItemsControl.Style>
                                <Style TargetType="ItemsControl">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding AIAssistantVM.History.Count}" Value="0">
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate>
                                                        <TextBlock Text="No history yet." Foreground="{DynamicResource TextMutedBrush}" HorizontalAlignment="Center" Margin="0,20,0,0"/>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ItemsControl.Style>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- Main Content -->
            <Grid Grid.Column="1" Margin="12,12,12,12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>    <!-- Editor Workspace Card -->
                    <RowDefinition Height="Auto"/> <!-- Options Panel -->
                </Grid.RowDefinitions>

                <!-- Text Editor Workspace Card -->
                <Border Grid.Row="0" Background="{DynamicResource PanelBgBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="8" Effect="{DynamicResource SoftGlow}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- TextBox -->
                    <TextBox Grid.Row="0" Text="{Binding MainText, UpdateSourceTrigger=PropertyChanged}" 
                             AcceptsReturn="True" 
                             TextWrapping="{Binding WrapLines, Converter={StaticResource BooleanToWrapConverter}}"
                             VerticalScrollBarVisibility="Auto"
                             Background="Transparent" 
                             BorderThickness="0"
                             Padding="12"
                             Foreground="{DynamicResource TextBrush}"
                             CaretBrush="{DynamicResource TextBrush}"
                             FontFamily="{DynamicResource CodeFontFamily}"
                             FontSize="{DynamicResource FontSizeNormal}"/>

                    <!-- Integrated Status Bar -->
                    <Border Grid.Row="1" Background="{DynamicResource StatusBgBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0" CornerRadius="0,0,8,8" Padding="16,8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            
                            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Margin="0,0,12,0" VerticalAlignment="Center">
                                    <Run Text="Words:" Foreground="{DynamicResource TextMutedBrush}"/> <Run Text="{Binding WordCount}" FontWeight="Bold" Foreground="{DynamicResource TextBrush}"/>
                                </TextBlock>
                                <TextBlock Margin="0,0,12,0" VerticalAlignment="Center">
                                    <Run Text="Chars:" Foreground="{DynamicResource TextMutedBrush}"/> <Run Text="{Binding CharacterCount}" FontWeight="Bold" Foreground="{DynamicResource TextBrush}"/>
                                </TextBlock>
                                <TextBlock Margin="0,0,12,0" VerticalAlignment="Center">
                                    <Run Text="Sentences:" Foreground="{DynamicResource TextMutedBrush}"/> <Run Text="{Binding SentenceCount}" FontWeight="Bold" Foreground="{DynamicResource TextBrush}"/>
                                </TextBlock>
                                <TextBlock Margin="0,0,12,0" VerticalAlignment="Center">
                                    <Run Text="Paragraphs:" Foreground="{DynamicResource TextMutedBrush}"/> <Run Text="{Binding ParagraphCount}" FontWeight="Bold" Foreground="{DynamicResource TextBrush}"/>
                                </TextBlock>
                                <TextBlock Margin="0,0,16,0" VerticalAlignment="Center">
                                    <Run Text="Lines:" Foreground="{DynamicResource TextMutedBrush}"/> <Run Text="{Binding LineCount}" FontWeight="Bold" Foreground="{DynamicResource TextBrush}"/>
                                </TextBlock>
                                <TextBlock Text="|" Foreground="{DynamicResource BorderBrush}" Margin="0,0,16,0" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding ReadingTimeSeconds, StringFormat='⏱️ ~\{0\}s'}" Foreground="{DynamicResource TextMutedBrush}" Margin="0,0,16,0" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding ReadabilityScore, StringFormat='📖 \{0\}'}" Foreground="{DynamicResource TextMutedBrush}" VerticalAlignment="Center"/>
                            </StackPanel>
                            
                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                <CheckBox Content="Wrap" IsChecked="{Binding WrapLines}" Margin="0,0,16,0" Style="{StaticResource ToggleSwitchStyle}" VerticalAlignment="Center"/>
                                <Button Content="✨ Clean Text" Command="{Binding CleanCommand}" Style="{StaticResource PrimaryButtonStyle}" Padding="12,6" Height="28" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <!-- Options Panel -->
            <Border Grid.Row="2" Background="{DynamicResource PanelBgBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="8" Margin="0,12,0,0" Padding="16" Effect="{DynamicResource SoftGlow}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="1.2*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Whitespace Section -->
                    <StackPanel Grid.Column="0" Margin="0,0,16,0">
                        <TextBlock Text="Whitespace" FontWeight="{DynamicResource FontWeightBold}" FontSize="{DynamicResource FontSizeNormal}" Margin="0,0,0,12" Foreground="{DynamicResource AccentBrush}" />
                        <CheckBox Content="Trim Start" IsChecked="{Binding ShouldTrimStart}" Style="{StaticResource ToggleSwitchStyle}"/>
                        <CheckBox Content="Trim End" IsChecked="{Binding ShouldTrimEnd}" Style="{StaticResource ToggleSwitchStyle}"/>
                        <CheckBox Content="Remove Multiple Spaces" IsChecked="{Binding ShouldRemoveMultipleSpaces}" Style="{StaticResource ToggleSwitchStyle}"/>
                        <CheckBox Content="Remove Multiple Lines" IsChecked="{Binding ShouldRemoveMultipleLines}" Style="{StaticResource ToggleSwitchStyle}"/>
                        <CheckBox Content="Remove All Line Breaks" IsChecked="{Binding ShouldRemoveAllLines}" Style="{StaticResource ToggleSwitchStyle}"/>
                    </StackPanel>

                    <!-- Letter Case Section -->
                    <StackPanel Grid.Column="1" Margin="0,0,16,0">
                        <TextBlock Text="Letter Case" FontWeight="{DynamicResource FontWeightBold}" FontSize="{DynamicResource FontSizeNormal}" Margin="0,0,0,12" Foreground="{DynamicResource AccentBrush}" />
                        <WrapPanel Orientation="Horizontal" Margin="0,4,0,0">
                            <RadioButton Content="None" IsChecked="{Binding IsDoNotChange, Mode=TwoWay}" GroupName="Case" Style="{StaticResource SegmentedRadioButtonStyle}" Margin="0,0,8,8"/>
                            <RadioButton Content="Sentence" IsChecked="{Binding IsSentenceCase, Mode=TwoWay}" GroupName="Case" Style="{StaticResource SegmentedRadioButtonStyle}" Margin="0,0,8,8"/>
                            <RadioButton Content="Title" IsChecked="{Binding IsTitleCase, Mode=TwoWay}" GroupName="Case" Style="{StaticResource SegmentedRadioButtonStyle}" Margin="0,0,8,8"/>
                            <RadioButton Content="UPPER" IsChecked="{Binding IsUppercase, Mode=TwoWay}" GroupName="Case" Style="{StaticResource SegmentedRadioButtonStyle}" Margin="0,0,8,8"/>
                            <RadioButton Content="lower" IsChecked="{Binding IsLowercase, Mode=TwoWay}" GroupName="Case" Style="{StaticResource SegmentedRadioButtonStyle}" Margin="0,0,8,8"/>
                        </WrapPanel>
                    </StackPanel>

                    <!-- Formatting Section -->
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Formatting" FontWeight="{DynamicResource FontWeightBold}" FontSize="{DynamicResource FontSizeNormal}" Margin="0,0,0,12" Foreground="{DynamicResource AccentBrush}" />
                        <CheckBox Content="Fix Punctuation Spacing" IsChecked="{Binding ShouldFixPunctuationSpace}" Style="{StaticResource ToggleSwitchStyle}"/>
                        <CheckBox Content="Remove HTML Tags" IsChecked="{Binding ShouldRemoveHtmlTags}" Style="{StaticResource ToggleSwitchStyle}"/>
                        <CheckBox Content="Convert Smart Quotes" IsChecked="{Binding ShouldConvertSmartQuotes}" Style="{StaticResource ToggleSwitchStyle}"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- AI Side Panel -->
        <Border Grid.Column="2" Width="280" Margin="0,12,12,12" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="8" Background="{DynamicResource PanelBgBrush}"
                Visibility="{Binding IsAIPanelOpen, Converter={StaticResource BooleanToVisibilityConverter}}"
                Effect="{DynamicResource SoftGlow}">
            <views:AIAssistantPanel DataContext="{Binding AIAssistantVM}" />
        </Border>
        </Grid>
    </Grid>
</Window>
